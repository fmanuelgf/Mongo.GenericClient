<Project>
  <!-- See https://aka.ms/dotnet/msbuild/customize for more details on customizing your build -->
  <PropertyGroup>
    <Target-Framework-Version>net10.0</Target-Framework-Version>
    <Package-Version>10.1.2</Package-Version>
    <MongoDB-Driver>3.7.*</MongoDB-Driver>
    <Coverlet-Collector>8.0.*</Coverlet-Collector>
    <Microsoft-NET-Test-Sdk>18.3.*</Microsoft-NET-Test-Sdk>
    <Microsoft-Extensions-DependencyInjection>10.0.*</Microsoft-Extensions-DependencyInjection>
    <NUnit>4.5.*</NUnit>
    <NUnit-Analyzers>4.12.*</NUnit-Analyzers>
    <NUnit3TestAdapter>6.2.*</NUnit3TestAdapter>
    <SpecFlow-NUnit>3.9.*</SpecFlow-NUnit>
  </PropertyGroup>
</Project>
